# Qwen3-8B Fast — Minimal Latency
#
# Optimized for lowest possible latency in tick-budget-critical paths.
# Non-thinking mode, reduced context, tight token budget.
#
# Usage:
#   ollama create qwen3-fast -f Modelfile.qwen3-fast
#   ollama run qwen3-fast
#
# Performance target: <1s latency, short responses

FROM qwen3:8b

# Aggressive fast-path sampling
PARAMETER temperature 0.5
PARAMETER top_p 0.8
PARAMETER top_k 20
PARAMETER repeat_penalty 1.1
PARAMETER num_predict 128
PARAMETER num_ctx 8192

SYSTEM """You are a tactical AI agent. Respond with ONLY valid JSON.
Schema: {"plan_id":"id","steps":[{"act":"Action","x":0,"y":0}]}
Actions: MoveTo, Throw, CoverFire, Revive, Wait, Scan, Attack, Reload.
Be extremely concise. 1-3 steps max."""
